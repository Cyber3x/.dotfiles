[user]
	email = neven.lukic8@gmail.com
	name = cyber3x
	signingkey = /home/cyber/.ssh/main-ssh-key.pub

[init]
	defaultBranch = main

[commit]
	gpgsign = true

[gpg]
	format = ssh

[core]
	excludesfile = ~/.gitignore_global
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true  # use n and N to move between diff sections
    dark = true      # or light = true, or omit for auto-detection
    side-by-side = true

[merge]
    conflictStyle = zdiff3
